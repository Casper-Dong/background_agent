# ── Core ──────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:1259
API_SECRET=change-me-to-a-random-string

# ── Postgres ──────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=background_agent
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent-local-dev

# ── Redis ─────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── GitHub ────────────────────────────────────────────
# Create a fine-grained personal access token with:
#   - Contents: Read and write
#   - Pull requests: Read and write
#   - Metadata: Read-only
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo
GITHUB_DEFAULT_BRANCH=main

# ── Slack ─────────────────────────────────────────────
# From https://api.slack.com/apps → your app → OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx
SLACK_SIGNING_SECRET=xxxxxxxxxxxxxxxx

# ── Agent ─────────────────────────────────────────────
# One of: claude-code | codex | opencode | mock
AGENT_TYPE=mock

# Only needed if AGENT_TYPE=claude-code
ANTHROPIC_API_KEY=

# Only needed if AGENT_TYPE=codex
OPENAI_API_KEY=

# ── Sandbox ───────────────────────────────────────────
SANDBOX_IMAGE=background-agent-sandbox
SANDBOX_TIMEOUT_SECONDS=1800
SANDBOX_MAX_ITERATIONS=5
# Local Docker socket path (used when DOCKER_HOST is not set)
DOCKER_SOCKET=/var/run/docker.sock
# Remote Docker endpoint (examples: tcp://docker.internal:2376, https://docker.example.com:2376)
DOCKER_HOST=
# Enable TLS when connecting to remote Docker (1/true/yes/on)
DOCKER_TLS_VERIFY=
# Optional directory containing ca.pem, cert.pem, key.pem
DOCKER_CERT_PATH=
# Optional PEM strings (raw with \n escapes or base64-encoded PEM)
DOCKER_TLS_CA_PEM=
DOCKER_TLS_CERT_PEM=
DOCKER_TLS_KEY_PEM=
# Optional explicit Docker API version (example: 1.43)
DOCKER_API_VERSION=

# ── Security ──────────────────────────────────────────
# Comma-separated list of allowed shell commands inside sandbox
COMMAND_ALLOWLIST=git,node,npm,npx,pnpm,yarn,python,python3,pip,docker,docker-compose,make,cargo,go,cat,ls,echo,mkdir,cp,mv,rm,chmod,grep,find,sed,awk,head,tail,wc,sort,uniq,diff,patch,curl,wget,tar,unzip,jq
